# Editor CMS — environment template. Copy to .env.local and fill in per client.
# Never commit .env.local (it is gitignored). No real values here.

# Active theme for the public renderer (M2). One of: conceito1, calytour, stub.
NEXT_PUBLIC_THEME=conceito1

# git-as-DB publish (M4, D-104). Fine-grained PAT with Contents:write on the content repo.
GITHUB_TOKEN=
# Optional overrides (defaults: lucasegea/ilhagrandehostel, main).
# GITHUB_REPO=owner/repo
# GITHUB_BRANCH=main

# --- Vercel Blob image uploads (M6, D-106) ---
# Read-write token for the Blob store the editor uploads photos to. Vercel >
# Storage > Blob > a store > ".env.local" tab. Read lazily at request time only, so a
# build without it stays green; a missing token fails clear at upload time (no silent
# fallback). On Vercel this is injected automatically when a Blob store is linked.
BLOB_READ_WRITE_TOKEN=

# --- Auth.js v5 (M5, D-105): Google OAuth + editor allowlist ---

# Secret used to sign the JWT session. Generate with: npx auth secret
# (or: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))")
AUTH_SECRET=

# Base URL Auth.js uses to build the OAuth callback. Local dev runs on port 3200.
# In production set this to the deployed origin (e.g. https://cms.example.com).
AUTH_URL=http://localhost:3200

# Google OAuth client (Google Cloud Console > APIs & Services > Credentials).
# Authorized redirect URI must be <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Comma-separated allowlist of editor emails. Only these may enter /admin and publish.
# Empty/unset locks everyone out (fail-clear). Example: ana@hostel.com, dev@agency.com
EDITOR_EMAILS=
